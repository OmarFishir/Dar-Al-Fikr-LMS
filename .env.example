# Required ----------------------------------------------------------------

# Random secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# MySQL connection string. On Railway, link a MySQL service and reference
# its variable: DATABASE_URL=${{ MySQL.MYSQL_URL }}
DATABASE_URL=mysql://user:pass@host:3306/dbname

# Required for production --------------------------------------------------

NODE_ENV=production

# Optional -----------------------------------------------------------------

# Email of the user to promote to admin on first login.
OWNER_EMAIL=

# Comma-separated emails that auto-receive the teacher role on first login.
TEACHER_EMAILS=teacher@school.edu

# OpenAI-compatible LLM. Without these, AI features show a "not configured"
# error but the rest of the app works.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Where uploaded files are written. To survive redeploys on Railway, attach
# a volume and mount it at this path.
STORAGE_DIR=./uploads
